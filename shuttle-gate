#!/usr/bin/env -S uv run --script --no-project --no-managed-python --no-python-downloads --no-cache --offline
# /// script
# requires-python = ">=3.14"
# dependencies = []
# ///
"""Clean host-side launcher for shuttle-gate.

This file intentionally uses only the Python standard library. Every operation
that needs project or networking dependencies runs in Docker.
"""

from __future__ import annotations

import fcntl
import hashlib
import json
import os
import re
import shutil
import stat
import subprocess
import sys
from collections.abc import Iterator
from contextlib import contextmanager, suppress
from pathlib import Path
from typing import NoReturn

ROOT = Path(__file__).resolve().parent
COMPOSE_FILE = ROOT / "docker-compose.yml"
STATE_DIR = ROOT / "state"
LAUNCH_MANIFEST = STATE_DIR / "runtime" / "launch.json"
LIFECYCLE_LOCK = STATE_DIR / ".lifecycle.lock"
PROJECT_PATTERN = re.compile(r"^[a-z0-9][a-z0-9_-]{0,62}$")
GENERATION_PATTERN = re.compile(r"^gen-[0-9a-f]{32}$")
OVERRIDE_PATTERN = re.compile(r"^compose\.override-[0-9a-f]{64}\.yaml$")
SHA256_PATTERN = re.compile(r"^[0-9a-f]{64}$")
LAUNCH_SCHEMA_VERSION = 2
MAX_LAUNCH_BYTES = 64 * 1024
MAX_INPUT_BYTES = 1024 * 1024
LOG_FLAG_OPTIONS = {
    "-f": "--follow",
    "--follow": "--follow",
    "-t": "--timestamps",
    "--timestamps": "--timestamps",
    "--no-color": "--no-color",
    "--no-log-prefix": "--no-log-prefix",
}
LOG_TAIL_OPTIONS = frozenset({"-n", "--tail"})
MAX_LOG_TAIL_LINES = 1_000_000
LOGS_USAGE = (
    "usage: ./shuttle-gate logs "
    "[--follow] [--timestamps] [--no-color] [--no-log-prefix] [--tail LINES|all]"
)


class LauncherError(Exception):
    """A user-visible host launcher failure."""


def _fail(message: str, exit_code: int = 2) -> NoReturn:
    print(f"shuttle-gate error: {message}", file=sys.stderr)
    raise SystemExit(exit_code)


def _base_environment() -> dict[str, str]:
    environment = os.environ.copy()
    environment.update(
        {
            "SG_ROOT": str(ROOT),
            "SG_UID": str(os.getuid()),
            "SG_GID": str(os.getgid()),
        }
    )
    return environment


def _compose_prefix() -> list[str]:
    if shutil.which("docker") is None:
        raise LauncherError("Docker is required but the docker command was not found")
    return ["docker", "compose", "--project-directory", str(ROOT), "-f", str(COMPOSE_FILE)]


def _bounded_digest(path: Path, label: str, *, private: bool = False) -> str:
    try:
        descriptor = os.open(path, os.O_RDONLY | os.O_CLOEXEC | os.O_NOFOLLOW)
    except OSError as exc:
        raise LauncherError(f"cannot open {label} {path}: {exc}") from exc
    try:
        info = os.fstat(descriptor)
        if not stat.S_ISREG(info.st_mode) or not 0 < info.st_size <= MAX_INPUT_BYTES:
            raise LauncherError(f"{label} must be a bounded regular file: {path}")
        if private and stat.S_IMODE(info.st_mode) & 0o077:
            raise LauncherError(f"{label} permissions are too open: {path}")
        with os.fdopen(descriptor, "rb") as source:
            descriptor = -1
            return hashlib.sha256(source.read(MAX_INPUT_BYTES + 1)).hexdigest()
    finally:
        if descriptor >= 0:
            os.close(descriptor)


def _manifest_project() -> str:
    try:
        info = LAUNCH_MANIFEST.stat(follow_symlinks=False)
        if not stat.S_ISREG(info.st_mode) or not 0 < info.st_size <= MAX_LAUNCH_BYTES:
            return "shuttle-gate"
        raw = json.loads(LAUNCH_MANIFEST.read_text(encoding="utf-8"))
        if not isinstance(raw, dict):
            return "shuttle-gate"
        candidate = raw.get("project")
        if isinstance(candidate, str) and PROJECT_PATTERN.fullmatch(candidate) is not None:
            return candidate
    except OSError, UnicodeError, json.JSONDecodeError:
        pass
    return "shuttle-gate"


def _project_compose_prefix() -> list[str]:
    return [*_compose_prefix(), "--project-name", _manifest_project()]


def _safe_manifest_file(
    value: object,
    label: str,
    required_root: Path,
    *,
    exact_parent: bool = False,
) -> Path:
    if not isinstance(value, str):
        raise LauncherError(f"launch manifest has an invalid {label} path")
    relative = Path(value)
    root_parts = required_root.parts
    below_root = relative.parts[: len(root_parts)] == root_parts and len(relative.parts) > len(
        root_parts
    )
    if (
        relative.is_absolute()
        or ".." in relative.parts
        or not below_root
        or (exact_parent and relative.parent != required_root)
    ):
        raise LauncherError(f"launch manifest {label} path is outside {required_root}")
    try:
        candidate = ROOT / relative
        path = candidate.resolve()
        allowed_root = (ROOT / required_root).resolve()
        path.relative_to(ROOT)
        path.relative_to(allowed_root)
    except (OSError, RuntimeError, ValueError) as exc:
        raise LauncherError(f"launch manifest {label} path escapes the project") from exc
    if exact_parent and path.parent != allowed_root:
        raise LauncherError(f"launch manifest {label} path escapes {required_root}")
    return candidate


def _validated_launch() -> tuple[str, Path]:
    try:
        info = LAUNCH_MANIFEST.stat(follow_symlinks=False)
        if not stat.S_ISREG(info.st_mode) or not 0 < info.st_size <= MAX_LAUNCH_BYTES:
            raise LauncherError(f"launch manifest is not a bounded regular file: {LAUNCH_MANIFEST}")
        raw = json.loads(LAUNCH_MANIFEST.read_text(encoding="utf-8"))
    except (FileNotFoundError, OSError, UnicodeError, json.JSONDecodeError) as exc:
        raise LauncherError(f"cannot read {LAUNCH_MANIFEST}: {exc}") from exc
    if not isinstance(raw, dict) or raw.get("schema_version") != LAUNCH_SCHEMA_VERSION:
        raise LauncherError("launch manifest has an unsupported format; run down, then up")
    project = raw.get("project")
    if not isinstance(project, str) or PROJECT_PATTERN.fullmatch(project) is None:
        raise LauncherError("launch manifest has an invalid project name")

    generation = raw.get("state_generation")
    if not isinstance(generation, str) or GENERATION_PATTERN.fullmatch(generation) is None:
        raise LauncherError("launch manifest has an invalid state generation")
    current = STATE_DIR / "current"
    try:
        if not stat.S_ISLNK(current.lstat().st_mode):
            raise LauncherError(f"persistent-state pointer is not a symlink: {current}")
        target = os.readlink(current)
    except OSError as exc:
        raise LauncherError(f"cannot read persistent-state pointer {current}: {exc}") from exc
    if target != f"generations/{generation}":
        raise LauncherError("persistent state changed after prepare; run down, then up")
    generation_root = STATE_DIR / "generations" / generation
    generation_manifest = generation_root / "manifest.json"
    try:
        if not stat.S_ISDIR(generation_root.stat(follow_symlinks=False).st_mode):
            raise LauncherError(f"state generation is not a directory: {generation_root}")
        manifest_info = generation_manifest.stat(follow_symlinks=False)
        if not stat.S_ISREG(manifest_info.st_mode) or not (
            0 < manifest_info.st_size <= MAX_LAUNCH_BYTES
        ):
            raise LauncherError(f"state generation manifest is invalid: {generation_manifest}")
        generation_value = json.loads(generation_manifest.read_text(encoding="utf-8"))
    except (FileNotFoundError, OSError, UnicodeError, json.JSONDecodeError) as exc:
        raise LauncherError(f"cannot validate state generation {generation}: {exc}") from exc
    if generation_value != {"generation": generation, "schema_version": 1}:
        raise LauncherError(f"state generation manifest does not match: {generation_manifest}")

    override = _safe_manifest_file(
        raw.get("compose_override"),
        "Compose override",
        Path("state/runtime"),
        exact_parent=True,
    )
    if OVERRIDE_PATTERN.fullmatch(override.name) is None:
        raise LauncherError("launch manifest has an invalid Compose override name")
    identity = _safe_manifest_file(raw.get("ssh_identity"), "SSH identity", Path("secrets"))
    known_hosts = _safe_manifest_file(
        raw.get("ssh_known_hosts"), "SSH known-hosts", Path("secrets")
    )
    expected_digests = {
        "config_digest": _bounded_digest(ROOT / "config.yaml", "configuration", private=True),
        "compose_override_digest": _bounded_digest(override, "Compose override", private=True),
        "ssh_identity_digest": _bounded_digest(identity, "SSH identity", private=True),
        "ssh_known_hosts_digest": _bounded_digest(known_hosts, "SSH known-hosts"),
    }
    for key, digest in expected_digests.items():
        recorded = raw.get(key)
        if not isinstance(recorded, str) or SHA256_PATTERN.fullmatch(recorded) is None:
            raise LauncherError(f"launch manifest has an invalid {key}")
        if recorded != digest:
            raise LauncherError(
                "configuration, credentials, or launch state changed; run down, then up"
            )
    return project, override


def _runtime_compose_prefix() -> list[str]:
    prefix = _compose_prefix()
    project, override = _validated_launch()
    prefix.extend(["--project-name", project])
    prefix.extend(["-f", str(override)])
    return prefix


@contextmanager
def _lifecycle_lock() -> Iterator[None]:
    if STATE_DIR.is_symlink():
        raise LauncherError(f"state directory must not be a symlink: {STATE_DIR}")
    try:
        STATE_DIR.mkdir(mode=0o700, parents=True, exist_ok=True)
        STATE_DIR.chmod(0o700)
    except OSError as exc:
        raise LauncherError(f"cannot prepare state directory {STATE_DIR}: {exc}") from exc
    flags = os.O_RDWR | os.O_CREAT | os.O_CLOEXEC | os.O_NOFOLLOW
    try:
        descriptor = os.open(LIFECYCLE_LOCK, flags, 0o600)
    except OSError as exc:
        raise LauncherError(f"cannot open lifecycle lock {LIFECYCLE_LOCK}: {exc}") from exc
    try:
        if not stat.S_ISREG(os.fstat(descriptor).st_mode):
            raise LauncherError(f"lifecycle lock must be a regular file: {LIFECYCLE_LOCK}")
        os.fchmod(descriptor, 0o600)
        try:
            fcntl.flock(descriptor, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError as exc:
            raise LauncherError("another up or down operation is already running") from exc
        except OSError as exc:
            raise LauncherError(f"cannot lock lifecycle file {LIFECYCLE_LOCK}: {exc}") from exc
        yield
    finally:
        with suppress(OSError):
            fcntl.flock(descriptor, fcntl.LOCK_UN)
        with suppress(OSError):
            os.close(descriptor)


def _run(command: list[str], *, capture: bool = False) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(
            command,
            check=False,
            env=_base_environment(),
            text=True,
            capture_output=capture,
        )
    except OSError as exc:
        raise LauncherError(f"cannot execute {command[0]}: {exc}") from exc


def _ensure_image(service: str) -> None:
    result = _run([*_compose_prefix(), "build", service])
    if result.returncode != 0:
        raise LauncherError(f"failed to build the {service} container")


def _run_tool(arguments: list[str], *, service: str = "tool") -> int:
    _ensure_image(service)
    result = _run(
        [
            *_compose_prefix(),
            "run",
            "--rm",
            "--no-deps",
            "--no-TTY",
            service,
            *arguments,
        ]
    )
    return result.returncode


def _up(arguments: list[str]) -> int:
    no_build = False
    if arguments == ["--no-build"]:
        no_build = True
    elif arguments:
        raise LauncherError("usage: ./shuttle-gate up [--no-build]")

    with _lifecycle_lock():
        project_prefix = _project_compose_prefix()
        running = _run(
            [*project_prefix, "ps", "--status", "running", "--quiet", "gateway"],
            capture=True,
        )
        if running.returncode != 0:
            raise LauncherError("failed to inspect the existing gateway")
        if running.stdout.strip():
            prefix = _runtime_compose_prefix()
        else:
            prepare_code = _run_tool(["prepare"])
            if prepare_code != 0:
                return prepare_code
            prefix = _runtime_compose_prefix()

        command = [*prefix, "up", "--detach", "--wait", "--wait-timeout", "60"]
        if not no_build:
            command.append("--build")
        return _run(command).returncode


def _down(arguments: list[str]) -> int:
    if arguments:
        raise LauncherError("usage: ./shuttle-gate down")
    with _lifecycle_lock():
        return _run([*_project_compose_prefix(), "down", "--remove-orphans"]).returncode


def _validated_log_tail(value: str) -> str:
    if value == "all":
        return value
    if not value.isascii() or not value.isdecimal():
        raise LauncherError(LOGS_USAGE)
    if len(value) > len(str(MAX_LOG_TAIL_LINES)) or int(value) > MAX_LOG_TAIL_LINES:
        raise LauncherError(f"log tail exceeds {MAX_LOG_TAIL_LINES} lines")
    return value


def _logs_command(compose_prefix: list[str], arguments: list[str]) -> list[str]:
    options: list[str] = []
    index = 0
    while index < len(arguments):
        argument = arguments[index]
        mapped = LOG_FLAG_OPTIONS.get(argument)
        if mapped is not None:
            options.append(mapped)
        elif argument in LOG_TAIL_OPTIONS:
            index += 1
            if index >= len(arguments):
                raise LauncherError(LOGS_USAGE)
            options.append(f"--tail={_validated_log_tail(arguments[index])}")
        elif argument.startswith("--tail="):
            options.append(f"--tail={_validated_log_tail(argument.removeprefix('--tail='))}")
        else:
            raise LauncherError(LOGS_USAGE)
        index += 1
    return [*compose_prefix, "logs", *options, "--", "gateway"]


def _logs(arguments: list[str]) -> int:
    return _run(_logs_command(_project_compose_prefix(), arguments)).returncode


def _status(arguments: list[str]) -> int:
    if arguments not in ([], ["--json"]):
        raise LauncherError("usage: ./shuttle-gate status [--json]")
    prefix = _project_compose_prefix()
    ps = _run([*prefix, "ps", "--status", "running", "--quiet"], capture=True)
    if ps.returncode != 0:
        return ps.returncode
    if not ps.stdout.strip():
        if arguments == ["--json"]:
            print('{"schema_version":1,"state":"stopped"}')
        else:
            print("shuttle-gate is stopped")
        return 1
    return _run(
        [
            *prefix,
            "exec",
            "--no-TTY",
            "gateway",
            "python",
            "-m",
            "shuttle_gate",
            "runtime-status",
            *arguments,
        ]
    ).returncode


def _print_help() -> None:
    print(
        """usage: ./shuttle-gate COMMAND [OPTIONS]

Commands:
  init                    Create local configuration and protected directories
  doctor                  Check host, Docker, kernel, SSH, and remote Python
  config validate         Validate config.yaml
  keys ...                Generate, rotate, or prune WireGuard keys
  peers list              List configured peers and generated state
  ssh-key ...             Generate a dedicated key or print setup instructions
  phone-config NAME       Generate one mobile WireGuard configuration
  up [--no-build]         Start the gateway and wait until it is ready
  down                    Stop the gateway cleanly
  status [--json]         Show gateway and peer status
  logs [OPTIONS]          Show gateway logs (use logs --help for supported options)
  version                 Print the project version
"""
    )


def main() -> int:
    arguments = sys.argv[1:]
    if not arguments or arguments[0] in {"-h", "--help"}:
        _print_help()
        return 0

    command, rest = arguments[0], arguments[1:]
    if command == "up":
        return _up(rest)
    if command == "down":
        return _down(rest)
    if command == "logs":
        if rest in (["-h"], ["--help"]):
            print(LOGS_USAGE)
            return 0
        return _logs(rest)
    if command == "status":
        return _status(rest)
    if command == "doctor":
        return _run_tool(["doctor", *rest], service="doctor")
    if command == "version":
        print((ROOT / "VERSION").read_text(encoding="utf-8").strip())
        return 0
    return _run_tool(arguments)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except LauncherError as error:
        _fail(str(error))
