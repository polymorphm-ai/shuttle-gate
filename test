#!/usr/bin/env -S uv run --script --locked --no-project
# /// script
# requires-python = ">=3.14"
# dependencies = [
#   "mypy>=1.19,<2",
#   "pydantic>=2.12,<3",
#   "pytest>=9,<10",
#   "pytest-cov>=7,<8",
#   "PyYAML>=6.0.2,<7",
#   "ruff>=0.14,<1",
#   "sshuttle==1.3.2",
#   "typer>=0.21,<1",
#   "types-PyYAML>=6.0.12,<7",
# ]
# ///
"""Run the locked shuttle-gate quality and integration gates."""

from __future__ import annotations

import os
import secrets
import shutil
import subprocess
import sys
import tempfile
from collections.abc import Mapping
from pathlib import Path
from typing import NoReturn

ROOT = Path(__file__).resolve().parent
COMPOSE_FILE = ROOT / "docker-compose.yml"
sys.path.insert(0, str(ROOT / "src"))
RUNTIME_MOUNT_PROBE = """
import os
from pathlib import Path

assert Path.cwd() == Path('/')
assert os.getuid() == 0 and os.getgid() == 0
assert Path('/config/config.yaml').read_text(encoding='ascii') == 'config'
try:
    Path('/config/config.yaml').write_text('changed', encoding='ascii')
except OSError:
    pass
else:
    raise SystemExit('configuration mount is writable')
Path('/state/.state.lock').write_text('lock', encoding='ascii')
Path('/run/shuttle-gate/output/probe').write_text('ok', encoding='ascii')
"""


def _fail(message: str) -> NoReturn:
    print(f"shuttle-gate test error: {message}", file=sys.stderr)
    raise SystemExit(2)


def _environment() -> dict[str, str]:
    environment = os.environ.copy()
    environment.update(
        {
            "PYTHONDONTWRITEBYTECODE": "1",
            "PYTHONPATH": str(ROOT / "src"),
        }
    )
    return environment


def _run(
    arguments: list[str],
    *,
    extra_environment: Mapping[str, str] | None = None,
) -> int:
    environment = _environment()
    if extra_environment is not None:
        environment.update(extra_environment)
    try:
        return subprocess.run(
            arguments,
            check=False,
            cwd=ROOT,
            env=environment,
        ).returncode
    except OSError as exc:
        _fail(f"cannot execute {arguments[0]}: {exc}")


def _python(module: str, *arguments: str) -> int:
    return _run([sys.executable, "-m", module, *arguments])


def _compose(*arguments: str) -> int:
    docker = shutil.which("docker")
    if docker is None:
        _fail("Docker is required for --integration")
    return _run(
        [
            docker,
            "compose",
            "--project-directory",
            str(ROOT),
            "--file",
            str(COMPOSE_FILE),
            *arguments,
        ]
    )


def _quality() -> int:
    uv = shutil.which("uv")
    if uv is None:
        _fail("uv was not found")
    with tempfile.TemporaryDirectory(prefix="shuttle-gate-quality-") as temporary:
        quality_environment = {
            "COVERAGE_FILE": str(Path(temporary) / "coverage"),
            "MYPY_CACHE_DIR": str(Path(temporary) / "mypy"),
            "RUFF_CACHE_DIR": str(Path(temporary) / "ruff"),
        }
        checks = (
            [uv, "lock", "--check", "--script", str(ROOT / "shuttle-gate")],
            [uv, "lock", "--check", "--script", str(ROOT / "test")],
            [
                sys.executable,
                "-m",
                "ruff",
                "format",
                "--check",
                "src",
                "tests",
                "shuttle-gate",
                "test",
            ],
            [sys.executable, "-m", "ruff", "check", "src", "tests", "shuttle-gate", "test"],
            [sys.executable, "-m", "mypy", "src", "tests"],
            [sys.executable, "-m", "mypy", "--strict", "shuttle-gate"],
            [sys.executable, "-m", "mypy", "--strict", "test"],
            [
                sys.executable,
                "-m",
                "pytest",
                "-p",
                "no:cacheprovider",
                "tests/unit",
                "--cov=shuttle_gate",
                "--cov-report=term-missing",
                "--cov-fail-under=90",
            ],
        )
        for command in checks:
            if _run(command, extra_environment=quality_environment) != 0:
                return 1
    return 0


def _native_integration() -> int:
    from shuttle_gate.host import RuntimePaths, bubblewrap_command, pasta_command

    with tempfile.TemporaryDirectory(prefix="shuttle-gate-runtime-probe-") as temporary:
        base = Path(temporary)
        project = base / "project"
        runtime_root = base / "runtime"
        runtime = RuntimePaths(
            instance_id="0" * 20,
            unit_name=f"shuttle-gate-{'0' * 20}.service",
            root=runtime_root,
            inputs=runtime_root / "inputs",
            output=runtime_root / "output",
            launch=runtime_root / "inputs/launch.json",
            bundle=runtime_root / "inputs/application.pyz",
        )
        for directory in (
            project / "secrets",
            project / "state",
            runtime.inputs,
            runtime.output,
        ):
            directory.mkdir(parents=True, exist_ok=True)
        (project / "config.yaml").write_text("config", encoding="ascii")
        (project / "state/.state.lock").write_text("", encoding="ascii")
        runtime.launch.write_text("launch\n", encoding="ascii")
        runtime.bundle.write_text("bundle\n", encoding="ascii")
        probe = bubblewrap_command(
            project,
            [sys.executable, "-c", RUNTIME_MOUNT_PROBE],
            network_namespace=True,
            project_read_only=True,
            runtime=runtime,
        )
        if _run(pasta_command(probe)) != 0:
            return 1
        output_probe = runtime.output / "probe"
        if (
            (project / "config.yaml").read_text(encoding="ascii") != "config"
            or (project / "state/.state.lock").read_text(encoding="ascii") != "lock"
            or output_probe.read_text(encoding="ascii") != "ok"
            or output_probe.stat().st_uid != os.getuid()
            or output_probe.stat().st_gid != os.getgid()
        ):
            _fail("runtime namespace mount or UID/GID mapping probe failed")

    command = [
        sys.executable,
        "-m",
        "pytest",
        "-p",
        "no:cacheprovider",
        "-m",
        "integration",
        "tests/integration",
    ]
    sandbox = bubblewrap_command(
        ROOT,
        command,
        network_namespace=True,
        project_read_only=True,
    )
    return _run(pasta_command(sandbox))


def _systemd_integration() -> int:
    from shuttle_gate.host import bubblewrap_command, pasta_command, systemd_run_command

    executable = shutil.which("true")
    if executable is None:
        _fail("true was not found")
    unit = f"shuttle-gate-{secrets.token_hex(10)}.service"
    sandbox = bubblewrap_command(
        ROOT,
        [executable],
        network_namespace=True,
        project_read_only=True,
    )
    command = systemd_run_command(unit, pasta_command(sandbox))
    command.insert(command.index("--"), "--wait")
    return _run(command)


def _container_integration() -> int:
    return _python(
        "pytest",
        "-p",
        "no:cacheprovider",
        "-m",
        "integration",
        "tests/integration",
    )


def main() -> int:
    arguments = sys.argv[1:]
    if arguments == ["--prepare-environment"]:
        return 0
    if arguments == ["--container-integration"]:
        return _container_integration()
    if arguments not in ([], ["--integration"]):
        _fail("usage: ./test [--integration]")
    if _quality() != 0:
        return 1
    if not arguments:
        return 0
    if _systemd_integration() != 0:
        return 1
    if _native_integration() != 0:
        return 1
    if _compose("config", "--quiet") != 0:
        return 1
    if _compose("build", "integration-test") != 0:
        return 1
    return _compose(
        "run",
        "--rm",
        "--no-deps",
        "--no-TTY",
        "integration-test",
    )


if __name__ == "__main__":
    raise SystemExit(main())
