#!/usr/bin/env -S uv run --script --locked --no-project
# /// script
# requires-python = ">=3.14"
# dependencies = [
#   "mypy>=1.19,<2",
#   "pydantic>=2.12,<3",
#   "pytest>=9,<10",
#   "pytest-cov>=7,<8",
#   "PyYAML>=6.0.2,<7",
#   "ruff>=0.14,<1",
#   "sshuttle==1.3.2",
#   "typer>=0.21,<1",
#   "types-PyYAML>=6.0.12,<7",
# ]
# ///
"""Run the locked shuttle-gate quality and integration gates."""

from __future__ import annotations

import os
import secrets
import shutil
import socket
import subprocess
import sys
import tempfile
import time
from collections.abc import Mapping
from pathlib import Path
from typing import NoReturn

ROOT = Path(__file__).resolve().parent
COMPOSE_FILE = ROOT / "docker-compose.yml"
sys.path.insert(0, str(ROOT / "src"))
RUNTIME_MOUNT_PROBE = """
import os
from pathlib import Path

assert Path.cwd() == Path('/')
assert os.getuid() == 0 and os.getgid() == 0
assert Path('/config/config.yaml').read_text(encoding='ascii') == 'config'
try:
    Path('/config/config.yaml').write_text('changed', encoding='ascii')
except OSError:
    pass
else:
    raise SystemExit('configuration mount is writable')
Path('/state/.state.lock').write_text('lock', encoding='ascii')
Path('/run/shuttle-gate/output/probe').write_text('ok', encoding='ascii')
"""


def _fail(message: str) -> NoReturn:
    print(f"shuttle-gate test error: {message}", file=sys.stderr)
    raise SystemExit(2)


def _environment() -> dict[str, str]:
    environment = os.environ.copy()
    environment.update(
        {
            "PYTHONDONTWRITEBYTECODE": "1",
            "PYTHONPATH": str(ROOT / "src"),
        }
    )
    return environment


def _run(
    arguments: list[str],
    *,
    extra_environment: Mapping[str, str] | None = None,
) -> int:
    environment = _environment()
    if extra_environment is not None:
        environment.update(extra_environment)
    try:
        return subprocess.run(
            arguments,
            check=False,
            cwd=ROOT,
            env=environment,
        ).returncode
    except OSError as exc:
        _fail(f"cannot execute {arguments[0]}: {exc}")


def _python(module: str, *arguments: str) -> int:
    return _run([sys.executable, "-m", module, *arguments])


def _compose(*arguments: str) -> int:
    docker = shutil.which("docker")
    if docker is None:
        _fail("Docker is required for --integration")
    return _run(
        [
            docker,
            "compose",
            "--project-directory",
            str(ROOT),
            "--file",
            str(COMPOSE_FILE),
            *arguments,
        ]
    )


def _quality() -> int:
    uv = shutil.which("uv")
    if uv is None:
        _fail("uv was not found")
    with tempfile.TemporaryDirectory(prefix="shuttle-gate-quality-") as temporary:
        quality_environment = {
            "COVERAGE_FILE": str(Path(temporary) / "coverage"),
            "MYPY_CACHE_DIR": str(Path(temporary) / "mypy"),
            "RUFF_CACHE_DIR": str(Path(temporary) / "ruff"),
        }
        checks = (
            [uv, "lock", "--check", "--script", str(ROOT / "shuttle-gate")],
            [uv, "lock", "--check", "--script", str(ROOT / "test")],
            [
                sys.executable,
                "-m",
                "ruff",
                "format",
                "--check",
                "src",
                "tests",
                "shuttle-gate",
                "test",
            ],
            [sys.executable, "-m", "ruff", "check", "src", "tests", "shuttle-gate", "test"],
            [sys.executable, "-m", "mypy", "src", "tests"],
            [sys.executable, "-m", "mypy", "--strict", "shuttle-gate"],
            [sys.executable, "-m", "mypy", "--strict", "test"],
            [
                sys.executable,
                "-m",
                "pytest",
                "-p",
                "no:cacheprovider",
                "tests/unit",
                "--cov=shuttle_gate",
                "--cov-report=term-missing",
                "--cov-fail-under=90",
            ],
        )
        for command in checks:
            if _run(command, extra_environment=quality_environment) != 0:
                return 1
    return 0


def _native_integration() -> int:
    from shuttle_gate.host import RuntimePaths, bubblewrap_command, pasta_command

    with tempfile.TemporaryDirectory(prefix="shuttle-gate-runtime-probe-") as temporary:
        base = Path(temporary)
        project = base / "instance"
        runtime_root = base / "runtime"
        runtime = RuntimePaths(
            instance_id="0" * 20,
            unit_name=f"shuttle-gate-{'0' * 20}.service",
            root=runtime_root,
            inputs=runtime_root / "inputs",
            output=runtime_root / "output",
            launch=runtime_root / "inputs/launch.json",
            bundle=runtime_root / "inputs/application.pyz",
        )
        for directory in (
            project / "secrets",
            project / "state",
            runtime.inputs,
            runtime.output,
        ):
            directory.mkdir(parents=True, exist_ok=True)
        (project / "config.yaml").write_text("config", encoding="ascii")
        (project / "state/.state.lock").write_text("", encoding="ascii")
        runtime.launch.write_text("launch\n", encoding="ascii")
        runtime.bundle.write_text("bundle\n", encoding="ascii")
        probe = bubblewrap_command(
            project,
            [sys.executable, "-c", RUNTIME_MOUNT_PROBE],
            network_namespace=True,
            instance_read_only=True,
            application_root=ROOT,
            runtime=runtime,
        )
        if _run(pasta_command(probe)) != 0:
            return 1
        output_probe = runtime.output / "probe"
        if (
            (project / "config.yaml").read_text(encoding="ascii") != "config"
            or (project / "state/.state.lock").read_text(encoding="ascii") != "lock"
            or output_probe.read_text(encoding="ascii") != "ok"
            or output_probe.stat().st_uid != os.getuid()
            or output_probe.stat().st_gid != os.getgid()
        ):
            _fail("runtime namespace mount or UID/GID mapping probe failed")

        test_instance = base / "test instance"
        test_instance.mkdir()
        command = [
            sys.executable,
            "-m",
            "pytest",
            "-p",
            "no:cacheprovider",
            "-m",
            "integration",
            str(ROOT / "tests/integration"),
        ]
        sandbox = bubblewrap_command(
            test_instance,
            command,
            network_namespace=True,
            instance_read_only=True,
            application_root=ROOT,
        )
        return _run(pasta_command(sandbox))


def _read_only_application_integration() -> int:
    """Prove the default instance never needs a writable application tree."""

    with tempfile.TemporaryDirectory(prefix="shuttle-gate-read-only-") as temporary:
        base = Path(temporary)
        application = base / "read-only application"
        application.mkdir()
        shutil.copy2(ROOT / "shuttle-gate", application / "shuttle-gate")
        shutil.copy2(ROOT / "config.example.yaml", application / "config.example.yaml")
        shutil.copytree(ROOT / "src", application / "src")
        original_entries = {path.relative_to(application) for path in application.rglob("*")}
        for path in application.rglob("*"):
            path.chmod(0o555 if path.is_dir() else 0o444)
        application.chmod(0o555)
        config_home = base / "  -config $ ; 🚀"
        try:
            status = _run(
                [sys.executable, str(application / "shuttle-gate"), "init"],
                extra_environment={"XDG_CONFIG_HOME": str(config_home)},
            )
            default_instance = config_home / "shuttle-gate/default"
            if (
                status != 0
                or not (default_instance / "config.yaml").is_file()
                or default_instance.stat().st_mode & 0o777 != 0o700
                or {path.relative_to(application) for path in application.rglob("*")}
                != original_entries
            ):
                _fail("read-only application or XDG default instance probe failed")
            return 0
        finally:
            application.chmod(0o755)
            for path in application.rglob("*"):
                if path.is_dir():
                    path.chmod(0o755)


def _systemd_integration() -> int:
    from shuttle_gate.host import (
        _build_application_bundle,
        bubblewrap_command,
        claim_command,
        pasta_command,
        prepare_socket_claims,
        systemd_run_command,
    )

    executable = shutil.which("true")
    if executable is None:
        _fail("true was not found")
    with tempfile.TemporaryDirectory(prefix="shuttle-gate-systemd-") as temporary:
        base = Path(temporary)
        (base / "instance").mkdir()
        bundle = base / "application.pyz"
        claim = base / "claims" / f"{secrets.token_hex(32)}.lock"
        _build_application_bundle(ROOT, bundle)
        prepare_socket_claims([claim])
        unit = f"shuttle-gate-{secrets.token_hex(10)}.service"
        sandbox = bubblewrap_command(
            base / "instance",
            [executable],
            network_namespace=True,
            instance_read_only=True,
            application_root=ROOT,
        )
        inner = claim_command([claim], pasta_command(sandbox))
        command = systemd_run_command(unit, inner, python_path=bundle)
        command.insert(command.index("--"), "--wait")
        return _run(command)


def _free_udp_port() -> int:
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as listener:
        listener.bind(("127.0.0.1", 0))
        return int(listener.getsockname()[1])


def _multi_instance_integration() -> int:
    """Run independent namespaces and prove duplicate host sockets fail closed."""

    from ipaddress import IPv4Address

    from shuttle_gate.config import load_config
    from shuttle_gate.host import (
        RuntimePaths,
        bubblewrap_command,
        claim_command,
        pasta_command,
        prepare_socket_claims,
        socket_claim_paths,
    )

    first_port = _free_udp_port()
    second_port = _free_udp_port()
    while second_port == first_port:
        second_port = _free_udp_port()
    base_config = load_config(ROOT / "config.example.yaml", private=False)
    processes: list[subprocess.Popen[str]] = []

    def start(instance: Path, port: int) -> subprocess.Popen[str]:
        wireguard = base_config.wireguard.model_copy(
            update={"bind_addresses": (IPv4Address("127.0.0.1"),), "listen_port": port}
        )
        config = base_config.model_copy(update={"wireguard": wireguard})
        sandbox = bubblewrap_command(
            instance,
            [sys.executable, "-c", "import time; time.sleep(30)"],
            network_namespace=True,
            instance_read_only=True,
            application_root=ROOT,
        )
        runtime_root = temporary_root / "session/shuttle-gate" / f"instance-{port}"
        runtime = RuntimePaths(
            instance_id="0" * 20,
            unit_name=f"shuttle-gate-{'0' * 20}.service",
            root=runtime_root,
            inputs=runtime_root / "inputs",
            output=runtime_root / "output",
            launch=runtime_root / "inputs/launch.json",
            bundle=runtime_root / "inputs/application.pyz",
        )
        claims = socket_claim_paths(runtime, config)
        prepare_socket_claims(claims)
        process = subprocess.Popen(
            claim_command(claims, pasta_command(sandbox, config)),
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            text=True,
            env=_environment(),
        )
        processes.append(process)
        return process

    def require_running(process: subprocess.Popen[str]) -> None:
        deadline = time.monotonic() + 2
        while time.monotonic() < deadline:
            if process.poll() is not None:
                _fail("an independent instance namespace stopped during startup")
            time.sleep(0.05)

    with tempfile.TemporaryDirectory(prefix="shuttle-gate-instances-") as temporary:
        temporary_root = Path(temporary)
        first_instance = temporary_root / "  -first $ ' \" ; 🚀"
        second_instance = temporary_root / "second instance"
        first_instance.mkdir()
        second_instance.mkdir()
        try:
            first = start(first_instance, first_port)
            require_running(first)
            second = start(second_instance, second_port)
            require_running(second)
            duplicate = start(second_instance, first_port)
            try:
                duplicate_status = duplicate.wait(timeout=5)
            except subprocess.TimeoutExpired:
                _fail("a duplicate host UDP socket was not rejected")
            if duplicate_status == 0:
                _fail("a duplicate host UDP socket unexpectedly succeeded")
            if first.poll() is not None or second.poll() is not None:
                _fail("a socket conflict disturbed an existing instance")
        finally:
            for process in processes:
                if process.poll() is None:
                    process.terminate()
            for process in processes:
                try:
                    process.wait(timeout=5)
                except subprocess.TimeoutExpired:
                    process.kill()
                    process.wait(timeout=5)
    return 0


def _container_integration() -> int:
    return _python(
        "pytest",
        "-p",
        "no:cacheprovider",
        "-m",
        "integration",
        "tests/integration",
    )


def main() -> int:
    arguments = sys.argv[1:]
    if arguments == ["--prepare-environment"]:
        return 0
    if arguments == ["--container-integration"]:
        return _container_integration()
    if arguments not in ([], ["--integration"]):
        _fail("usage: ./test [--integration]")
    if _quality() != 0:
        return 1
    if not arguments:
        return 0
    if _read_only_application_integration() != 0:
        return 1
    if _systemd_integration() != 0:
        return 1
    if _multi_instance_integration() != 0:
        return 1
    if _native_integration() != 0:
        return 1
    if _compose("config", "--quiet") != 0:
        return 1
    if _compose("build", "integration-test") != 0:
        return 1
    return _compose(
        "run",
        "--rm",
        "--no-deps",
        "--no-TTY",
        "integration-test",
    )


if __name__ == "__main__":
    raise SystemExit(main())
